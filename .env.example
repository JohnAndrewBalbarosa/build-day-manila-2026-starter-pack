# Team API key used as Authorization: Bearer <token> (matches team.api_key in the dashboard database).
TEAM_TOKEN=21aa3b86-3de7-4c65-a8b5-b90b1d0f43ba

# LLM API key for your agent (OpenAI, Anthropic, Google, etc.). Use the name your
